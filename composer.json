{
  "name": "npcink/npcink-abilities-toolkit",
  "description": "Standalone WordPress Abilities API package toolkit for agent-callable abilities, with optional Npcink AI integration.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3.5"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ],
    "files": [
      "includes/functions.php"
    ]
  },
  "scripts": {
    "validate:composer": "composer validate --no-check-publish",
    "check:boundary": "@php scripts/check-project-boundary.php",
    "check:contracts": "@php scripts/check-ability-contracts.php",
    "check:consumer": "@php scripts/check-consumer-handoff.php",
    "check:workflow-consumer": "@php scripts/check-workflow-consumer-proof.php",
    "check:official-stack": "@php scripts/check-official-stack-compatibility.php",
    "check:mcp-exposure": "@php scripts/check-mcp-exposure.php",
    "check:provider-demo": "@php scripts/check-provider-demo.php",
    "check:catalog": "@php scripts/audit-ability-catalog.php tests/fixtures/core-governance-catalog-snapshot.json",
    "check:wporg": "@php scripts/check-wordpress-org-review-rules.php",
    "check:plugin-package": "bash scripts/check-plugin-package.sh",
    "lint:php": "@php tests/lint.php",
    "analyse:phpstan": "phpstan analyse --memory-limit=512M",
    "perf:smoke": "@php tests/performance-smoke.php",
    "smoke:wp": "bash tests/smoke-wp.sh",
    "test": "@php tests/run.php",
    "test:all": [
      "@validate:composer",
      "@check:boundary",
      "@check:contracts",
      "@check:consumer",
      "@check:workflow-consumer",
      "@check:official-stack",
      "@check:mcp-exposure",
      "@check:provider-demo",
      "@check:catalog",
      "@check:wporg",
      "@perf:smoke",
      "@test",
      "@lint:php"
    ]
  }
}
