{
  "name": "npcink/npcink-abilities-toolkit",
  "description": "Standalone WordPress Abilities API package toolkit for agent-callable abilities, with optional Npcink AI integration.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3.5"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ],
    "files": [
      "includes/functions.php"
    ]
  },
  "scripts": {
    "validate:composer": "composer validate --no-check-publish",
    "audit:composer": "composer audit --locked --no-interaction",
    "check:boundary": "@php scripts/check-project-boundary.php",
    "check:contracts": "@php scripts/check-ability-contracts.php",
    "check:consumer": "@php scripts/check-consumer-handoff.php",
    "check:workflow-consumer": "@php scripts/check-workflow-consumer-proof.php",
    "check:official-stack": "@php scripts/check-official-stack-compatibility.php",
    "check:mcp-exposure": "@php scripts/check-mcp-exposure.php",
    "check:provider-demo": "@php scripts/check-provider-demo.php",
    "check:legacy-ability-ids": "@php scripts/audit-legacy-ability-ids.php",
    "check:legacy-recipe-ids": "@php scripts/audit-legacy-recipe-ids.php",
    "check:catalog": "@php scripts/audit-ability-catalog.php tests/fixtures/core-governance-catalog-snapshot.json",
    "check:wporg": "@php scripts/check-wordpress-org-review-rules.php",
    "check:plugin-package": "bash scripts/check-plugin-package.sh",
    "lint:php": "@php tests/lint.php",
    "analyse:phpstan": "phpstan analyse --memory-limit=512M",
    "perf:smoke": "@php tests/performance-smoke.php",
    "perf:bootstrap": "@php tests/bootstrap-performance.php",
    "pilot:gutenberg-composer": "@php tests/gutenberg-composer-pilot/run-pilot.php",
    "eval:lab": "sh scripts/eval-lab.sh eval:task",
    "eval:gutenberg-recipe:suite": "@php tests/gutenberg-recipe-eval/export-default-suite.php",
    "eval:gutenberg-recipe:judge:cases": "@php tests/gutenberg-recipe-eval/export-promptfoo-judge-cases.php",
    "eval:gutenberg-recipe:judge": "command -v promptfoo >/dev/null || { echo \"Install promptfoo first: npm install -g promptfoo\"; exit 1; }; GUTENBERG_RECIPE_JUDGE_OUTPUT=\"${GUTENBERG_RECIPE_JUDGE_OUTPUT:-tests/gutenberg-recipe-eval/generated/promptfoo-judge-primary.json}\"; GUTENBERG_RECIPE_JUDGE_GRADER=\"${GUTENBERG_RECIPE_JUDGE_GRADER:-openai:gpt-4.1-mini}\"; rm -f \"$GUTENBERG_RECIPE_JUDGE_OUTPUT\"; promptfoo eval -c tests/gutenberg-recipe-eval/promptfoo-judge.yaml --grader \"$GUTENBERG_RECIPE_JUDGE_GRADER\" --output \"$GUTENBERG_RECIPE_JUDGE_OUTPUT\" --no-table",
    "eval:gutenberg-recipe:judge:eval-lab": [
      "Composer\\Config::disableProcessTimeout",
      "bash -c 'set -e; php tests/gutenberg-recipe-eval/export-default-suite.php \"$@\"; php tests/gutenberg-recipe-eval/export-promptfoo-judge-cases.php \"$@\"; TOOLKIT_ROOT=\"$(pwd)\"; sh scripts/eval-lab.sh task=gutenberg_judge_cross \"input=$TOOLKIT_ROOT/tests/gutenberg-recipe-eval/generated/promptfoo-judge-cases.csv\" \"$@\"' --"
    ],
    "eval:gutenberg-recipe:judge:compare": "@php tests/gutenberg-recipe-eval/compare-ai-judge-results.php",
    "smoke:wp": "bash tests/smoke-wp.sh",
    "smoke:block-theme-host-proof": "bash scripts/block-theme-host-proof.sh",
    "smoke:wp-minimum": "bash scripts/minimum-wordpress-smoke.sh",
    "e2e:official-stack": "bash scripts/official-stack-e2e.sh",
    "release:verify": "bash scripts/release-verify.sh",
    "release:prepare-wporg": "bash scripts/prepare-wporg-svn-release.sh",
    "release:zip": "bash scripts/build-release-zip.sh",
    "test": "@php tests/run.php",
    "test:all": [
      "@validate:composer",
      "@audit:composer",
      "@check:boundary",
      "@check:contracts",
      "@check:consumer",
      "@check:workflow-consumer",
      "@check:official-stack",
      "@check:mcp-exposure",
      "@check:provider-demo",
      "@check:legacy-ability-ids",
      "@check:legacy-recipe-ids",
      "@check:catalog",
      "@check:wporg",
      "@perf:bootstrap",
      "@perf:smoke",
      "@pilot:gutenberg-composer",
      "@test",
      "@lint:php"
    ]
  }
}
