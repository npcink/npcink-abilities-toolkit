msgid "<code>/wp-json/npcink-abilities-toolkit/v1/contract</code>"
msgstr "<code>/wp-json/npcink-abilities-toolkit/v1/contract</code>"

#. Found in description list item.
msgid "<code>/wp-json/wp-abilities/v1/abilities/{namespace}/{name}/run</code>"
msgstr "<code>/wp-json/wp-abilities/v1/abilities/{namespace}/{name}/run</code>"

