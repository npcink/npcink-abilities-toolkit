#: includes/Packages/Core_Destructive_Package.php:1396
#: includes/Packages/Core_Write_Package.php:6247
msgid "Taxonomy is invalid."
msgstr "La taxonomie n'est pas valide."

#: includes/Packages/Core_Destructive_Package.php:547
msgid "Valid terms or term_ids are required for add/remove operations."
msgstr "Des termes valides ou term_ids sont requis pour les opérations d'ajout/suppression."

#: includes/Packages/Core_Destructive_Package.php:566
msgid "Current user cannot edit this post."
msgstr "L'utilisateur actuel ne peut pas modifier ce message."

#. translators: %d: query limit.
#: includes/Packages/Core_Destructive_Package.php:598
#, php-format
msgid "Matched post count reached limit (%d); more matching posts may exist."
msgstr ""
"Le nombre de publications correspondantes a atteint la limite (%d) ; d'autres "
"messages correspondants peuvent exister."

#: includes/Packages/Core_Destructive_Package.php:603
msgid ""
"Replace operation has no valid terms; matching posts will have these terms "
"cleared."
msgstr ""
"L’opération de remplacement n’a pas de termes valides ; les messages "
"correspondants verront ces termes effacés."

