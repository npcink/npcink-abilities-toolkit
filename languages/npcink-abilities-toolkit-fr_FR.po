#: includes/Packages/Core_Read_Package.php:73
msgid "WordPress Read Abilities"
msgstr "WordPress Capacités de lecture"

#: includes/Packages/Core_Read_Package.php:74
msgid "Read-only WordPress site, content, and structure abilities."
msgstr "Capacités de site, de contenu et de structure WordPress en lecture seule."

#: includes/Packages/Core_Read_Package.php:80
msgid "WordPress Page Abilities"
msgstr "WordPress Capacités des pages"

#: includes/Packages/Core_Read_Package.php:81
msgid "Read-only WordPress page discovery and inspection abilities."
msgstr "Capacités de découverte et d'inspection de pages WordPress en lecture seule."

#: includes/Packages/Core_Read_Package.php:87
msgid "WordPress Diagnostics"
msgstr "WordPress Diagnostic"

#: includes/Packages/Core_Read_Package.php:88
msgid "Redacted WordPress environment diagnostics for Abilities API clients."
msgstr "Diagnostics de l'environnement WordPress rédigés pour les clients Abilities API."

#: includes/Packages/Core_Read_Package.php:94
msgid "Workflow Recipe Definitions"
msgstr "Définitions des recettes de workflow"

#: includes/Packages/Core_Read_Package.php:95
msgid ""
"Read-only workflow recipe definitions for host-side ability composition."
msgstr ""
"Définitions de recettes de workflow en lecture seule pour la composition des "
"capacités côté hôte."

#: includes/Packages/Core_Read_Package.php:189
msgid "List Workflow Recipes"
msgstr "Répertorier les recettes de flux de travail"

#: includes/Packages/Core_Read_Package.php:190
msgid ""
"Returns read-only workflow recipe definitions for host-side ability "
"composition without executing workflow steps."
msgstr ""
"Renvoie les définitions de recettes de workflow en lecture seule pour la "
"composition des capacités côté hôte sans exécuter les étapes du workflow."

#: includes/Packages/Core_Read_Package.php:212
msgid "Get Workflow Recipe"
msgstr "Obtenir la recette du flux de travail"

#: includes/Packages/Core_Read_Package.php:213
msgid ""
"Returns one read-only workflow recipe definition by recipe id or case id "
"without executing workflow steps."
msgstr ""
"Renvoie une définition de recette de workflow en lecture seule par ID de "
"recette ou ID de cas sans exécuter d'étapes de workflow."

#: includes/Packages/Core_Read_Package.php:233
msgid "List Media"
msgstr "Liste des médias"

#: includes/Packages/Core_Read_Package.php:234
msgid "Returns a paginated list of media library attachments."
msgstr "Renvoie une liste paginée des pièces jointes de la bibliothèque multimédia."

#: includes/Packages/Core_Read_Package.php:279
msgid "Resolve Media Attachment By URL"
msgstr "Résoudre la pièce jointe multimédia avant URL"

#: includes/Packages/Core_Read_Package.php:280
msgid ""
"Resolves a same-site uploads URL to bounded media attachment candidates with "
"read-only match evidence."
msgstr ""
"Résout les téléchargements URL sur le même site vers des candidats de pièce "
"jointe multimédia délimités avec une preuve de correspondance en lecture "
"seule."

#: includes/Packages/Core_Read_Package.php:327
msgid "List Terms"
msgstr "Termes de la liste"

#: includes/Packages/Core_Read_Package.php:328
msgid "Returns a paginated list of terms for a taxonomy."
msgstr "Renvoie une liste paginée de termes pour une taxonomie."

#: includes/Packages/Core_Read_Package.php:371
msgid "List Taxonomy Terms"
msgstr "Répertorier les termes de la taxonomie"

#: includes/Packages/Core_Read_Package.php:372
msgid ""
"Returns a paginated term list for one taxonomy, including parent information."
msgstr ""
"Renvoie une liste de termes paginés pour une taxonomie, y compris les "
"informations sur les parents."

#: includes/Packages/Core_Read_Package.php:418
msgid "List Categories"
msgstr "Catégories de liste"

#: includes/Packages/Core_Read_Package.php:419
msgid "Returns a paginated list of post categories."
msgstr "Renvoie une liste paginée de catégories de publications."

#: includes/Packages/Core_Read_Package.php:449
msgid "List Tags"
msgstr "Liste des balises"

#: includes/Packages/Core_Read_Package.php:450
msgid "Returns a paginated list of post tags."
msgstr "Renvoie une liste paginée de balises de publication."

#: includes/Packages/Core_Read_Package.php:480
msgid "Get Term"
msgstr "Obtenir le terme"

#: includes/Packages/Core_Read_Package.php:481
msgid "Returns details for one taxonomy term by id or slug."
msgstr "Renvoie les détails d’un terme de taxonomie par identifiant ou slug."

#: includes/Packages/Core_Read_Package.php:510
msgid "List Comments"
msgstr "Liste des commentaires"

#: includes/Packages/Core_Read_Package.php:511
msgid "Returns a paginated list of comments."
msgstr "Renvoie une liste paginée de commentaires."

#: includes/Packages/Core_Read_Package.php:553
msgid "Resolve Internal Link Targets"
msgstr "Résoudre les cibles de liens internes"

#: includes/Packages/Core_Read_Package.php:554
msgid ""
"Finds local published content that can serve as internal-link targets for a "
"post draft or optimization workflow."
msgstr ""
"Recherche le contenu publié local qui peut servir de cibles de liens internes "
"pour un workflow de post-ébauche ou d'optimisation."

#: includes/Packages/Core_Read_Package.php:599
msgid "Build Inline Image Blocks"
msgstr "Créer des blocs d'images en ligne"

#: includes/Packages/Core_Read_Package.php:600
msgid ""
"Converts uploaded inline image rows into append-ready Gutenberg image blocks "
"without writing post content."
msgstr ""
"Convertit les lignes d'images en ligne téléchargées en blocs d'images "
"Gutenberg prêts à être ajoutés sans écrire de contenu de publication."

#: includes/Packages/Core_Read_Package.php:635
msgid "Build Media SEO Assets"
msgstr "Créer des éléments multimédias SEO"

#: includes/Packages/Core_Read_Package.php:636
msgid ""
"Builds a canonical media SEO enrichment asset list from article media "
"workflow upload outputs."
msgstr ""
"Crée une liste d'actifs d'enrichissement multimédia canonique SEO à partir des"
"sorties de téléchargement du flux de travail multimédia d'article."

#: includes/Packages/Core_Read_Package.php:668
msgid "GEO Analysis"
msgstr "GEO Analyse"

#: includes/Packages/Core_Read_Package.php:669
msgid ""
"Builds deterministic GEO and AI visibility issues, recommendations, and "
"evidence from article text."
msgstr ""
"Crée des problèmes de visibilité déterministes GEO et AI, des recommandations "
"et des preuves à partir du texte de l'article."

#: includes/Packages/Core_Read_Package.php:701
msgid "Optimize Media Metadata"
msgstr "Optimiser les métadonnées multimédias"

#: includes/Packages/Core_Read_Package.php:702
msgid ""
"Builds deterministic media title, alt, caption, description, source, and "
"disclosure suggestions from article and media context."
msgstr ""
"Crée des suggestions déterministes de titre, d'alt, de légende, de "
"description, de source et de divulgation à partir du contexte de l'article et "
"du média."

#: includes/Packages/Core_Read_Package.php:735
msgid "Position Inline Image Blocks"
msgstr "Positionner les blocs d'images en ligne"

#: includes/Packages/Core_Read_Package.php:736
msgid ""
"Places generated inline image blocks after matching paragraph, heading, or "
"anchor targets and falls back to append."
msgstr ""
"Place les blocs d'images en ligne générés après avoir fait correspondre les "
"cibles de paragraphe, de titre ou d'ancrage et revient à l'ajout."

#: includes/Packages/Core_Read_Package.php:771
msgid "Build Article Optimization Report"
msgstr "Créer un rapport d'optimisation des articles"

#: includes/Packages/Core_Read_Package.php:772
msgid ""
"Composes SEO, GEO, internal-link, and media optimization sections into one "
"deterministic report."
msgstr ""
"Compose les sections SEO, GEO, de liens internes et d'optimisation des médias "
"dans un seul rapport déterministe."

#: includes/Packages/Core_Read_Package.php:807
msgid "Build SEO Report Context"
msgstr "Créer un contexte de rapport SEO"

#: includes/Packages/Core_Read_Package.php:808
msgid ""
"Builds lightweight deterministic SEO issues and recommendations for article "
"optimization workflows."
msgstr ""
"Crée des problèmes et des recommandations déterministes légers SEO pour les "
"flux de travail d'optimisation d'articles."

#: includes/Packages/Core_Read_Package.php:840
msgid "Read Post Optimization Context"
msgstr "Lire le contexte de post-optimisation"

#: includes/Packages/Core_Read_Package.php:841
msgid ""
"Reads a post title, excerpt, content, slug, categories, tags, SEO fields, "
"template, and format snapshot for article optimization workflows."
msgstr ""
"Lit le titre d'un article, un extrait, un contenu, un slug, des catégories, "
"des balises, des champs SEO, un modèle et un instantané de format pour les "
"flux de travail d'optimisation d'article."

#: includes/Packages/Core_Read_Package.php:872
msgid "Build Article Single Optimization Suggest"
msgstr "Créer une suggestion d'optimisation unique pour un article"

#: includes/Packages/Core_Read_Package.php:873
msgid ""
"Builds one canonical single-article optimization suggestion envelope for "
"title, taxonomy, excerpt, slug, SEO, content, and GEO improvements."
msgstr ""
"Crée une enveloppe canonique de suggestion d'optimisation d'un seul article "
"pour les améliorations du titre, de la taxonomie, de l'extrait, du slug, de "
"SEO, du contenu et de GEO."

#: includes/Packages/Core_Read_Package.php:914
msgid "Build Article Optimization Apply Plan"
msgstr "Créer un plan d'optimisation d'article"

#: includes/Packages/Core_Read_Package.php:915
msgid ""
"Builds one conservative apply plan from the read-only article optimization "
"report without applying writes."
msgstr ""
"Construit un plan d'application conservateur à partir du rapport "
"d'optimisation d'article en lecture seule sans appliquer d'écritures."

#: includes/Packages/Core_Read_Package.php:950
msgid "Compose Article Optimization Apply Result"
msgstr "Composer l'article Optimisation Appliquer le résultat"

#: includes/Packages/Core_Read_Package.php:951
msgid ""
"Composes report, apply plan, safe apply result, and remaining advisory "
"changes into one deterministic envelope."
msgstr ""
"Rédige le rapport, le plan d'application, le résultat d'application sécurisé "
"et les modifications consultatives restantes dans une seule enveloppe "
"déterministe."

#: includes/Packages/Core_Read_Package.php:984
msgid "Extract Reference Post Style"
msgstr "Extraire le style de publication de référence"

#: includes/Packages/Core_Read_Package.php:985
msgid ""
"Reads reference posts and returns a compact writing-style profile for "
"article workflows."
msgstr ""
"Lit les articles de référence et renvoie un profil de style d'écriture compact"
"pour les flux de travail d'articles."

#: includes/Packages/Core_Read_Package.php:1032
msgid "Extract Site Style Baseline"
msgstr "Extraire la ligne de base du style du site"

#: includes/Packages/Core_Read_Package.php:1033
msgid ""
"Extracts a lightweight site-wide or author-specific writing-style baseline "
"from recent posts."
msgstr ""
"Extrait une ligne de base de style d'écriture légère à l'échelle du site ou "
"spécifique à l'auteur à partir des publications récentes."

#: includes/Packages/Core_Read_Package.php:1080
msgid "Build Article Production Fingerprint"
msgstr "Créer une empreinte digitale de production d'articles"

#: includes/Packages/Core_Read_Package.php:1081
msgid ""
"Builds a stable lightweight production fingerprint for article dedupe and "
"result summaries."
msgstr ""
"Crée une empreinte de production légère et stable pour la déduplication des "
"articles et les résumés des résultats."

#: includes/Packages/Core_Read_Package.php:1124
msgid "Check Article Production Duplicate"
msgstr "Vérifier les doublons de production d'articles"

#: includes/Packages/Core_Read_Package.php:1125
msgid ""
"Checks whether a lightweight article production fingerprint already exists "
"on a post."
msgstr ""
"Vérifie si une empreinte digitale de production d’article léger existe déjà "
"sur une publication."

#: includes/Packages/Core_Read_Package.php:1152
msgid "Review Article Output Light"
msgstr "Article de revue Lumière de sortie"

#: includes/Packages/Core_Read_Package.php:1153
msgid ""
"Builds lightweight local article quality, style, image, and AI-risk review "
"signals without model calls."
msgstr ""
"Crée des signaux légers d'évaluation de la qualité, du style, de l'image et "
"des risques AI des articles locaux sans appels de modèle."

#: includes/Packages/Core_Read_Package.php:1190
msgid "Compose Article Production Result"
msgstr "Composer le résultat de la production de l'article"

#: includes/Packages/Core_Read_Package.php:1191
msgid ""
"Summarizes the article production mainline with result mode, degraded "
"reasons, fingerprint, handoff, and next action."
msgstr ""
"Résume la ligne principale de production d’articles avec le mode résultat, les"
"raisons dégradées, l’empreinte digitale, le transfert et l’action suivante."

#: includes/Packages/Core_Read_Package.php:1226
msgid "Compose Article Draft Result"
msgstr "Rédiger le résultat du brouillon de l'article"

#: includes/Packages/Core_Read_Package.php:1227
msgid ""
"Composes one canonical draft workflow result with draft content, metadata "
"resolution, shared SEO/GEO review, and handoff hints."
msgstr ""
"Compose un brouillon canonique de résultat de flux de travail avec un "
"brouillon de contenu, une résolution de métadonnées, une révision partagée "
"SEO/GEO et des conseils de transfert."

#: includes/Packages/Core_Read_Package.php:1263
msgid "Resolve Article Publication Decision"
msgstr "Résoudre la décision de publication de l'article"

#: includes/Packages/Core_Read_Package.php:1264
msgid ""
"Resolves a deterministic article publish, schedule, review, or draft handoff "
"after quality and duplicate checks."
msgstr ""
"Résout une publication, une planification, une révision ou un transfert de "
"brouillon d'article déterministe après des contrôles de qualité et des "
"doublons."

#: includes/Packages/Core_Read_Package.php:1302
msgid "Build Article Style Profile"
msgstr "Créer un profil de style d'article"

#: includes/Packages/Core_Read_Package.php:1303
msgid ""
"Merges baseline, reference, and explicit writing-style hints into one "
"lightweight article style profile."
msgstr ""
"Fusionne les conseils de base, de référence et de style d'écriture explicite "
"en un seul profil de style d'article léger."

#: includes/Packages/Core_Read_Package.php:1339
msgid "List Pages"
msgstr "Pages de liste"

#: includes/Packages/Core_Read_Package.php:1340
msgid ""
"Lists WordPress pages with status, parent, search, sorting, and pagination "
"filters."
msgstr ""
"Répertorie WordPress pages avec des filtres d'état, parent, de recherche, de "
"tri et de pagination."

#: includes/Packages/Core_Read_Package.php:1372
msgid "Get Page"
msgstr "Obtenir la page"

#: includes/Packages/Core_Read_Package.php:1373
msgid ""
"Returns a single WordPress page, including content, template, hierarchy, "
"author, and optional meta."
msgstr ""
"Renvoie une seule page WordPress, comprenant le contenu, le modèle, la "
"hiérarchie, l'auteur et les méta facultatives."

#: includes/Packages/Core_Read_Package.php:1419
msgid "Inspect Page Structure"
msgstr "Inspecter la structure des pages"

#: includes/Packages/Core_Read_Package.php:1420
msgid ""
"Inspects WordPress page hierarchy, template usage, and orphaned parent "
"relationships without modifying pages."
msgstr ""
"Inspecte la hiérarchie des pages WordPress, l'utilisation des modèles et les "
"relations parents orphelins sans modifier les pages."

#: includes/Packages/Core_Read_Package.php:1449
msgid "List Pages Tree"
msgstr "Arborescence des pages de liste"

#: includes/Packages/Core_Read_Package.php:1450
msgid ""
"Returns a hierarchical page tree for navigation and site-structure review."
msgstr ""
"Renvoie une arborescence de pages hiérarchique pour la navigation et l'examen "
"de la structure du site."

#: includes/Packages/Core_Read_Package.php:1490
msgid "Get Content Publishing Checklist"
msgstr "Obtenir la liste de contrôle pour la publication de contenu"

#: includes/Packages/Core_Read_Package.php:1491
msgid ""
"Returns a deterministic pre-publish readiness checklist for one post or page "
"without applying changes."
msgstr ""
"Renvoie une liste de contrôle déterministe de préparation à la pré-publication"
"pour une publication ou une page sans appliquer de modifications."

#: includes/Packages/Core_Read_Package.php:1535
msgid "Get Content Inventory Health"
msgstr "Obtenez la santé de l’inventaire de contenu"

#: includes/Packages/Core_Read_Package.php:1536
msgid ""
"Scans a bounded content inventory and summarizes missing titles, thin "
"content, excerpt gaps, media gaps, SEO metadata gaps, and stale content."
msgstr ""
"Analyse un inventaire de contenu limité et résume les titres manquants, le "
"contenu léger, les lacunes dans les extraits, les lacunes dans les médias, les"
"lacunes dans les métadonnées SEO et le contenu obsolète."

#: includes/Packages/Core_Read_Package.php:1581
msgid "Get Nonproduction Content Inventory"
msgstr "Obtenir l'inventaire du contenu hors production"

#: includes/Packages/Core_Read_Package.php:1582
msgid ""
"Detects bounded smoke, fixture, and nonproduction content that may distort "
"content, taxonomy, comment, and operations diagnostics without mutating the "
"site."
msgstr ""
"Détecte le contenu limité de fumée, de luminaires et de non-production qui "
"peut déformer le contenu, la taxonomie, les commentaires et les diagnostics "
"des opérations sans muter le site."

#: includes/Packages/Core_Read_Package.php:1615
msgid "Build Nonproduction Content Cleanup Plan"
msgstr "Créer un plan de nettoyage du contenu hors production"

#: includes/Packages/Core_Read_Package.php:1616
msgid ""
"Builds a read-only cleanup plan for detected nonproduction content, mapping "
"each candidate to existing governed write abilities without trashing or "
"deleting anything."
msgstr ""
"Crée un plan de nettoyage en lecture seule pour le contenu de non-production "
"détecté, en mappant chaque candidat aux capacités d'écriture gouvernées "
"existantes sans rien détruire ni supprimer."

#: includes/Packages/Core_Read_Package.php:1650
msgid "Build Content Inventory Fix Plan"
msgstr "Créer un plan de correctif pour l'inventaire de contenu"

#: includes/Packages/Core_Read_Package.php:1651
msgid ""
"Maps bounded content inventory issues to reviewable fix actions that reuse "
"existing governed write abilities without mutating posts."
msgstr ""
"Mappe les problèmes d’inventaire de contenu limité à des actions de correction"
"révisables qui réutilisent les capacités d’écriture gouvernées existantes sans"
"mutation des publications."

#: includes/Packages/Core_Read_Package.php:1685
msgid "Get Bulk Publishing Checklist"
msgstr "Obtenir la liste de contrôle de publication en masse"

#: includes/Packages/Core_Read_Package.php:1686
msgid ""
"Runs the read-only publishing checklist for a bounded list of posts and "
"returns batch readiness totals."
msgstr ""
"Exécute la liste de contrôle de publication en lecture seule pour une liste "
"limitée de publications et renvoie les totaux de préparation par lots."

#: includes/Packages/Core_Read_Package.php:1732
msgid "Get Internal Link Opportunity Report"
msgstr "Obtenir le rapport sur les opportunités de liens internes"

#: includes/Packages/Core_Read_Package.php:1733
msgid ""
"Builds a post-id based internal-link opportunity report with candidate "
"targets, anchor suggestions, and placement hints."
msgstr ""
"Crée un rapport d'opportunité de liens internes basé sur l'identification "
"post-identification avec des cibles de candidats, des suggestions d'ancrage et"
"des conseils de placement."

#: includes/Packages/Core_Read_Package.php:1773
msgid "Get Site Operations Dashboard"
msgstr "Obtenir le tableau de bord des opérations du site"

#: includes/Packages/Core_Read_Package.php:1774
msgid ""
"Builds a bounded read-only site operations dashboard for content status, "
"inventory issues, taxonomy health, comments, and media signals."
msgstr ""
"Crée un tableau de bord limité des opérations du site en lecture seule pour "
"l'état du contenu, les problèmes d'inventaire, l'état de la taxonomie, les "
"commentaires et les signaux multimédias."

#: includes/Packages/Core_Read_Package.php:1803
msgid "Get Post Publish Risk Report"
msgstr "Obtenir le rapport sur les risques après publication"

#: includes/Packages/Core_Read_Package.php:1804
msgid ""
"Builds a read-only publish risk report for one post from checklist, SEO/GEO, "
"revision, and internal-link signals."
msgstr ""
"Crée un rapport sur les risques de publication en lecture seule pour une "
"publication à partir de la liste de contrôle, de SEO/GEO, de la révision et "
"des signaux de lien interne."

#: includes/Packages/Core_Read_Package.php:1834
msgid "Get Article Publish Preflight Context"
msgstr "Obtenir le contexte de contrôle en amont de la publication de l'article"

#: includes/Packages/Core_Read_Package.php:1835
msgid ""
"Aggregates post context, publishing checklist, publish risk, workflow "
"context, and calendar context for host-side publish preflight workflows "
"without writing."
msgstr ""
"Regroupe le contexte de publication, la liste de contrôle de publication, le "
"risque de publication, le contexte de flux de travail et le contexte de "
"calendrier pour les flux de travail de contrôle en amont de publication côté "
"hôte sans écriture."

#: includes/Packages/Core_Read_Package.php:1867
msgid "Get Content Refresh Opportunities"
msgstr "Obtenez des opportunités d’actualisation du contenu"

#: includes/Packages/Core_Read_Package.php:1868
msgid ""
"Scans a bounded content set and returns stale, thin, SEO-light, answer-"
"light, and low-link refresh opportunities."
msgstr ""
"Analyse un ensemble de contenu limité et renvoie des opportunités "
"d'actualisation obsolètes, fines, légères SEO, légères en réponse et à liaison"
"faible."

#: includes/Packages/Core_Read_Package.php:1900
msgid "Get Old Article Refresh Context"
msgstr "Récupérer le contexte d'actualisation de l'ancien article"

#: includes/Packages/Core_Read_Package.php:1901
msgid ""
"Aggregates refresh opportunities, SEO/GEO gaps, site style baseline, "
"internal-link graph health, and optional selected-post link opportunities "
"for host-side old article refresh workflows."
msgstr ""
"Agrége les opportunités d'actualisation, les écarts SEO/GEO, la ligne de base "
"du style du site, l'état du graphique des liens internes et les opportunités "
"facultatives de liens de publication sélectionnées pour les flux de travail "
"d'actualisation des anciens articles côté hôte."

#: includes/Packages/Core_Read_Package.php:1935
msgid "Get Internal Link Graph Health"
msgstr "Obtenez la santé du graphique de lien interne"

#: includes/Packages/Core_Read_Package.php:1936
msgid ""
"Scans a bounded content set and summarizes outgoing links, incoming links, "
"orphan posts, and candidate internal-link pairs."
msgstr ""
"Analyse un ensemble de contenu limité et résume les liens sortants, les liens "
"entrants, les publications orphelines et les paires de liens internes "
"candidats."

#: includes/Packages/Core_Read_Package.php:1968
msgid "Get Media Cleanup Opportunities"
msgstr "Obtenez des opportunités de nettoyage des médias"

#: includes/Packages/Core_Read_Package.php:1969
msgid ""
"Scans a bounded media inventory and returns cleanup opportunities for "
"metadata gaps, source gaps, and likely unused assets."
msgstr ""
"Analyse un inventaire multimédia limité et renvoie des opportunités de "
"nettoyage pour les lacunes dans les métadonnées, les lacunes dans les sources "
"et les ressources probablement inutilisées."

#: includes/Packages/Core_Read_Package.php:1998
msgid "List Media Backups"
msgstr "Répertorier les sauvegardes multimédias"

#: includes/Packages/Core_Read_Package.php:1999
msgid ""
"Lists recorded backup files for one attachment media operation history "
"without mutating media."
msgstr ""
"Répertorie les fichiers de sauvegarde enregistrés pour l'historique des "
"opérations d'un support de pièce jointe sans mutation du support."

#: includes/Packages/Core_Read_Package.php:2028
msgid "Build Media Inventory Fix Plan"
msgstr "Créer un plan de correctif pour l'inventaire des médias"

#: includes/Packages/Core_Read_Package.php:2029
msgid ""
"Maps bounded media inventory issues to reviewable metadata and cleanup "
"actions that reuse existing governed write abilities without mutating media."
msgstr ""
"Mappe les problèmes d’inventaire des médias limités aux métadonnées "
"consultables et aux actions de nettoyage qui réutilisent les capacités "
"d’écriture gouvernées existantes sans muter les médias."

#: includes/Packages/Core_Read_Package.php:2068
msgid "Build Media Reference Repair Plan"
msgstr "Créer un plan de réparation de référence multimédia"

#: includes/Packages/Core_Read_Package.php:2069
msgid ""
"Scans post content for hard-coded URLs to a previously replaced media file "
"and builds governed patch-post-content actions without mutating posts."
msgstr ""
"Analyse le contenu de la publication à la recherche de URL codés en dur dans "
"un fichier multimédia précédemment remplacé et crée des actions de "
"patch-post-contenu régies sans muter les publications."

#: includes/Packages/Core_Read_Package.php:2104
msgid "Build Media Settings Reference Repair Plan"
msgstr "Plan de réparation de référence des paramètres de support de construction"

#: includes/Packages/Core_Read_Package.php:2105
msgid ""
"Scans selected WordPress options and theme mods for hard-coded URLs to a "
"previously replaced media file and builds governed exact replacement actions "
"without mutating settings."
msgstr ""
"Analyse les options WordPress et les mods de thème sélectionnés pour les URL "
"codés en dur dans un fichier multimédia précédemment remplacé et crée des "
"actions de remplacement exactes régies sans modifier les paramètres."

#: includes/Packages/Core_Read_Package.php:2148
msgid "Get Taxonomy Consolidation Suggestions"
msgstr "Obtenez des suggestions de consolidation de taxonomie"

#: includes/Packages/Core_Read_Package.php:2149
msgid ""
"Scans taxonomy terms and suggests read-only consolidation candidates for "
"empty, duplicate, similar, and unused terms."
msgstr ""
"Analyse les termes de taxonomie et suggère des candidats à la consolidation en"
"lecture seule pour les termes vides, en double, similaires et inutilisés."

#: includes/Packages/Core_Read_Package.php:2179
msgid "Propose Post Taxonomy Terms"
msgstr "Proposer des termes post-taxonomie"

#: includes/Packages/Core_Read_Package.php:2180
msgid ""
"Builds a deterministic post taxonomy assignment proposal from existing terms "
"without mutating the post or creating terms."
msgstr ""
"Construit une proposition d'affectation de post-taxonomie déterministe à "
"partir de termes existants sans muter la publication ni créer de termes."

#: includes/Packages/Core_Read_Package.php:2224
msgid "Get Page Structure Health"
msgstr "Obtenir la santé de la structure des pages"

#: includes/Packages/Core_Read_Package.php:2225
msgid ""
"Scans one page or a bounded page set and reports heading, CTA, content "
"depth, and block structure health."
msgstr ""
"Analyse une page ou un ensemble de pages délimité et rapporte le titre, CTA, "
"la profondeur du contenu et l'état de la structure des blocs."

#: includes/Packages/Core_Read_Package.php:2254
msgid "Get SEO GEO Gap Report"
msgstr "Obtenez SEO GEO rapport sur les écarts"

#: includes/Packages/Core_Read_Package.php:2255
msgid ""
"Builds a bounded SEO/GEO gap report from topic coverage, refresh "
"opportunities, answer structure, and SEO metadata signals."
msgstr ""
"Crée un rapport d'écart limité SEO/GEO à partir de la couverture du sujet, des"
"opportunités d'actualisation, de la structure des réponses et des signaux de "
"métadonnées SEO."

#: includes/Packages/Core_Read_Package.php:2286
msgid "Get Site Style Baseline"
msgstr "Obtenir la référence de style du site"

#: includes/Packages/Core_Read_Package.php:2287
msgid ""
"Returns a compact read-only site-wide or author-specific writing style "
"baseline from recent posts."
msgstr ""
"Renvoie une ligne de base de style d'écriture compacte en lecture seule à "
"l'échelle du site ou spécifique à l'auteur à partir des publications récentes."

#: includes/Packages/Core_Read_Package.php:2316
msgid "Build Article Workflow Context"
msgstr "Créer un contexte de flux de travail d'article"

#: includes/Packages/Core_Read_Package.php:2317
msgid ""
"Builds one read-only context bundle for article refresh, publish, or new-"
"article workflows without model routing."
msgstr ""
"Crée un ensemble de contexte en lecture seule pour les flux de travail "
"d'actualisation, de publication ou de nouvel article sans routage de modèle."

#: includes/Packages/Core_Read_Package.php:2346
msgid "Get Publishing Calendar Context"
msgstr "Obtenir le contexte du calendrier de publication"

#: includes/Packages/Core_Read_Package.php:2347
msgid ""
"Returns scheduled posts, draft backlog, pending review items, and near-term "
"publishing cadence context."
msgstr ""
"Renvoie les publications planifiées, le carnet de brouillons, les éléments de "
"révision en attente et le contexte de cadence de publication à court terme."

#: includes/Packages/Core_Read_Package.php:2376
msgid "Get Media Inventory Health"
msgstr "Obtenez la santé de votre inventaire multimédia"

#: includes/Packages/Core_Read_Package.php:2377
msgid ""
"Scans a bounded media inventory and summarizes missing alt text, captions, "
"descriptions, source metadata, and format attention."
msgstr ""
"Analyse un inventaire multimédia limité et résume le texte alternatif, les "
"légendes, les descriptions, les métadonnées sources et l'attention au format "
"manquants."

#: includes/Packages/Core_Read_Package.php:2420
msgid "Inspect Media Asset"
msgstr "Inspecter les ressources multimédias"

#: includes/Packages/Core_Read_Package.php:2421
msgid ""
"Inspects one attachment file and returns read-only format, size, dimension, "
"and optimization recommendations."
msgstr ""
"Inspecte un fichier de pièce jointe et renvoie des recommandations en lecture "
"seule sur le format, la taille, les dimensions et l'optimisation."

#: includes/Packages/Core_Read_Package.php:2473
msgid "Build Media Derivative Cloud Request"
msgstr "Créer une demande de cloud dérivé multimédia"

#: includes/Packages/Core_Read_Package.php:2474
msgid ""
"Builds a read-only request contract for a host or Cloud addon to generate an "
"optimized media derivative without uploading, calling Cloud, or mutating "
"WordPress."
msgstr ""
"Crée un contrat de requête en lecture seule pour un hôte ou un Cloud Addon "
"afin de générer un dérivé multimédia optimisé sans télécharger, appeler Cloud "
"ou muter WordPress."

#: includes/Packages/Core_Read_Package.php:2534
msgid "Build Media Optimization Plan"
msgstr "Élaborer un plan d'optimisation des médias"

#: includes/Packages/Core_Read_Package.php:2535
msgid ""
"Builds a read-only one-attachment optimization plan that combines reviewed "
"media metadata updates with a governed derivative adoption action for one "
"Core approval."
msgstr ""
"Crée un plan d'optimisation en lecture seule à une pièce jointe qui combine "
"les mises à jour des métadonnées multimédias examinées avec une action "
"d'adoption dérivée gouvernée pour une approbation Core."

#: includes/Packages/Core_Read_Package.php:2568
msgid "Build Media Rename Plan"
msgstr "Créer un plan de renommage des médias"

#: includes/Packages/Core_Read_Package.php:2569
msgid ""
"Builds a read-only one-attachment rename plan for a reviewed target media "
"file name and exact post-content reference updates without mutating "
"WordPress."
msgstr ""
"Crée un plan de renommage d'une pièce jointe en lecture seule pour un nom de "
"fichier multimédia cible révisé et des mises à jour exactes de référence après"
"le contenu sans mutation de WordPress."

#: includes/Packages/Core_Read_Package.php:2606
msgid "Build Media Derivative Batch Plan"
msgstr "Créer un plan par lots dérivé des médias"

#: includes/Packages/Core_Read_Package.php:2607
msgid ""
"Builds a bounded read-only plan for batch Cloud media derivative previews "
"from local media filters without calling Cloud, creating proposals, or "
"mutating WordPress."
msgstr ""
"Crée un plan limité en lecture seule pour les aperçus dérivés de médias Cloud "
"par lots à partir de filtres multimédias locaux sans appeler Cloud, créer des "
"propositions ou muter WordPress."

#: includes/Packages/Core_Read_Package.php:2690
msgid "Get Post SEO GEO Readiness"
msgstr "Préparez-vous à la publication SEO GEO"

#: includes/Packages/Core_Read_Package.php:2691
msgid ""
"Returns one deterministic SEO/GEO readiness snapshot for a post, including "
"metadata, content-depth, question, and media signals."
msgstr ""
"Renvoie un instantané déterministe de préparation SEO/GEO pour une "
"publication, comprenant les métadonnées, la profondeur du contenu, la question"
"et les signaux multimédias."

#: includes/Packages/Core_Read_Package.php:2732
msgid "Get Site Topic Coverage Report"
msgstr "Obtenir le rapport sur la couverture des sujets du site"

#: includes/Packages/Core_Read_Package.php:2733
msgid ""
"Builds a bounded site topic coverage summary from post titles, terms, and "
"content snippets without model routing."
msgstr ""
"Crée un résumé limité de la couverture des sujets du site à partir des titres "
"des articles, des termes et des extraits de contenu sans routage de modèle."

#: includes/Packages/Core_Read_Package.php:2775
msgid "Get Taxonomy Inventory Health"
msgstr "Obtenez l’état de l’inventaire de taxonomie"

#: includes/Packages/Core_Read_Package.php:2776
msgid ""
"Scans a bounded taxonomy term inventory and summarizes empty, unused, "
"duplicate, and hierarchy attention signals."
msgstr ""
"Analyse un inventaire limité de termes de taxonomie et résume les signaux "
"d'attention vides, inutilisés, en double et hiérarchiques."

#: includes/Packages/Core_Read_Package.php:2820
msgid "Get Revision Change Risk Report"
msgstr "Obtenir le rapport sur les risques liés aux modifications de révision"

#: includes/Packages/Core_Read_Package.php:2821
msgid ""
"Reads recent revisions for one post and summarizes title, content length, "
"block count, and recency change-risk signals."
msgstr ""
"Lit les révisions récentes d'un article et résume le titre, la longueur du "
"contenu, le nombre de blocs et les signaux de risque de changement de récence."

#: includes/Packages/Core_Read_Package.php:2903
msgid "Workflow recipe definition was not found."
msgstr "La définition de la recette de workflow est introuvable."

#: includes/Packages/Core_Read_Package.php:3088
#: includes/Packages/Read_Traits/Content_Inventory_Read_Methods.php:35
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:44
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:281
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:393
msgid "Post type does not exist."
msgstr "Le type de message n'existe pas."

#: includes/Packages/Core_Read_Package.php:3116
msgid "Content is required to generate an excerpt proposal."
msgstr "Le contenu est requis pour générer une proposition d’extrait."

#: includes/Packages/Core_Read_Package.php:3131
msgid "Local read-only excerpt proposal generated from explicit content input."
msgstr ""
"Proposition d'extrait local en lecture seule générée à partir d'une entrée de "
"contenu explicite."

#: includes/Packages/Core_Read_Package.php:3191
msgid "Post metadata plan resolved."
msgstr "Plan de publication des métadonnées résolu."

#: includes/Packages/Core_Read_Package.php:3343
msgid "Menu was not found."
msgstr "Le menu n'a pas été trouvé."

#: includes/Packages/Core_Write_Package.php:56
msgid ""
"Host-governed WordPress write abilities with dry-run previews and external "
"approval."
msgstr ""
"Capacités d'écriture WordPress gérées par l'hôte avec aperçus à sec et "
"approbation externe."

#: includes/Packages/Core_Write_Package.php:79
msgid "Create Draft"
msgstr "Créer un brouillon"

#: includes/Packages/Core_Write_Package.php:80
msgid ""
"Creates a draft post or page after host approval, or returns a dry-run "
"preview by default."
msgstr ""
"Crée un brouillon de publication ou de page après l'approbation de l'hôte, ou "
"renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:126
msgid "Update Post"
msgstr "Mettre à jour le message"

#: includes/Packages/Core_Write_Package.php:127
msgid ""
"Updates a post title, content, or excerpt after host approval, or returns a "
"dry-run preview by default."
msgstr ""
"Met à jour le titre, le contenu ou l'extrait d'un article après l'approbation "
"de l'hôte, ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:160
msgid "Set Post SEO Meta"
msgstr "Définir la méta de la publication SEO"

#: includes/Packages/Core_Write_Package.php:161
msgid ""
"Updates SEO title and description metadata for one post after host approval, "
"or returns a dry-run preview by default."
msgstr ""
"Met à jour SEO les métadonnées de titre et de description d'une publication "
"après l'approbation de l'hôte, ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:192
msgid "Patch Post Content"
msgstr "Contenu de la publication de correctif"

#: includes/Packages/Core_Write_Package.php:193
msgid ""
"Applies text patch operations to saved post content after host approval, or "
"returns a dry-run preview by default."
msgstr ""
"Applique les opérations de correctif de texte au contenu de la publication "
"enregistrée après l'approbation de l'hôte ou renvoie un aperçu à sec par "
"défaut."

#: includes/Packages/Core_Write_Package.php:242
msgid "Patch Setting Value"
msgstr "Valeur du paramètre de patch"

#: includes/Packages/Core_Write_Package.php:243
msgid ""
"Applies exact text replacement operations to one option or theme mod after "
"host approval, or returns a dry-run preview by default."
msgstr ""
"Applique des opérations de remplacement de texte exactes à une option ou un "
"module de thème après l'approbation de l'hôte, ou renvoie un aperçu à sec par "
"défaut."

#: includes/Packages/Core_Write_Package.php:294
msgid "Update Post Blocks"
msgstr "Mettre à jour les blocs de publication"

#: includes/Packages/Core_Write_Package.php:295
msgid ""
"Writes Gutenberg blocks into post content after host approval, or returns a "
"dry-run preview by default."
msgstr ""
"Écrit des blocs Gutenberg dans le contenu de la publication après "
"l'approbation de l'hôte ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:339
msgid "Set Post Slug"
msgstr "Définir le limace de poteau"

#: includes/Packages/Core_Write_Package.php:340
msgid ""
"Updates a post slug after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Met à jour un post-slug après l’approbation de l’hôte ou renvoie un aperçu à "
"sec par défaut."

#: includes/Packages/Core_Write_Package.php:368
msgid "Set Post Author"
msgstr "Définir l'auteur du message"

#: includes/Packages/Core_Write_Package.php:369
msgid ""
"Updates a post author after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Met à jour l’auteur d’une publication après l’approbation de l’hôte ou renvoie"
"un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:396
msgid "Set Post Template"
msgstr "Définir le modèle de publication"

#: includes/Packages/Core_Write_Package.php:397
msgid ""
"Updates a post template after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Met à jour un modèle de publication après l’approbation de l’hôte ou renvoie "
"un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:424
msgid "Set Post Format"
msgstr "Définir le format de publication"

#: includes/Packages/Core_Write_Package.php:425
msgid ""
"Updates a post format after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Met à jour un format de publication après l'approbation de l'hôte ou renvoie "
"un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:455
msgid "Create Term"
msgstr "Créer un terme"

#: includes/Packages/Core_Write_Package.php:456
msgid ""
"Creates a taxonomy term after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Crée un terme de taxonomie après l'approbation de l'hôte ou renvoie un aperçu "
"à sec par défaut."

#: includes/Packages/Core_Write_Package.php:486
msgid "Update Term"
msgstr "Durée de mise à jour"

#: includes/Packages/Core_Write_Package.php:487
msgid ""
"Updates a taxonomy term after host approval, or returns a dry-run preview by "
"default."
msgstr ""
"Met à jour un terme de taxonomie après l’approbation de l’hôte ou renvoie un "
"aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:521
msgid "Set Post Terms"
msgstr "Définir les conditions de publication"

#: includes/Packages/Core_Write_Package.php:522
msgid ""
"Updates a post taxonomy terms in replace, append, or remove mode after host "
"approval, or returns a dry-run preview by default."
msgstr ""
"Met à jour les termes d'une post-taxonomie en mode remplacement, ajout ou "
"suppression après l'approbation de l'hôte, ou renvoie un aperçu à sec par "
"défaut."

#: includes/Packages/Core_Write_Package.php:572
msgid "Update Media Details"
msgstr "Mettre à jour les détails du média"

#: includes/Packages/Core_Write_Package.php:573
msgid ""
"Updates attachment title, alt, caption, description, and attribution fields "
"after host approval, or returns a dry-run preview by default."
msgstr ""
"Met à jour les champs de titre, alt, légende, description et attribution de la"
"pièce jointe après l’approbation de l’hôte, ou renvoie un aperçu à sec par "
"défaut."

#: includes/Packages/Core_Write_Package.php:619
msgid "Upload Media From URL"
msgstr "Télécharger des médias depuis URL"

#: includes/Packages/Core_Write_Package.php:620
msgid ""
"Downloads one remote media asset into the WordPress media library after host "
"approval, or returns a dry-run preview by default."
msgstr ""
"Télécharge une ressource multimédia distante dans la bibliothèque multimédia "
"WordPress après l'approbation de l'hôte, ou renvoie un aperçu à sec par "
"défaut."

#: includes/Packages/Core_Write_Package.php:667
msgid "Optimize Media Asset"
msgstr "Optimiser les ressources multimédias"

#: includes/Packages/Core_Write_Package.php:668
msgid ""
"Generates an optimized derivative for one image attachment after host "
"approval, preserving the original file."
msgstr ""
"Génère un dérivé optimisé pour une pièce jointe d'image après l'approbation de"
"l'hôte, en préservant le fichier d'origine."

#: includes/Packages/Core_Write_Package.php:702
msgid "Replace Media File"
msgstr "Remplacer le fichier multimédia"

#: includes/Packages/Core_Write_Package.php:703
msgid ""
"Replaces one attachment main file with a previously generated optimized "
"derivative after host approval, preserving backup metadata for restore-media-"
"backup."
msgstr ""
"Remplace un fichier principal de pièce jointe par un dérivé optimisé généré "
"précédemment après l'approbation de l'hôte, préservant ainsi les métadonnées "
"de sauvegarde pour la restauration-média-sauvegarde."

#: includes/Packages/Core_Write_Package.php:742
msgid "Restore Media Backup"
msgstr "Restaurer la sauvegarde du support"

#: includes/Packages/Core_Write_Package.php:743
msgid ""
"Restores one attachment by copying a recorded backup back to the original "
"media path and URL after host approval."
msgstr ""
"Restaure une pièce jointe en copiant une sauvegarde enregistrée sur le chemin "
"du support d'origine et URL après l'approbation de l'hôte."

#: includes/Packages/Core_Write_Package.php:781
msgid "Rename Media File"
msgstr "Renommer le fichier multimédia"

#: includes/Packages/Core_Write_Package.php:782
msgid ""
"Renames one attachment main file within its current uploads directory after "
"host approval, preserving a backup and rollback metadata."
msgstr ""
"Renomme un fichier principal de pièce jointe dans son répertoire de "
"téléchargement actuel après l'approbation de l'hôte, en préservant les "
"métadonnées de sauvegarde et de restauration."

#: includes/Packages/Core_Write_Package.php:820
msgid "Adopt Cloud Media Derivative"
msgstr "Adoptez le dérivé Cloud Media"

#: includes/Packages/Core_Write_Package.php:821
msgid ""
"Adopts one approved short-lived Cloud derivative artifact as the attachment "
"main file, with local backup and rollback metadata."
msgstr ""
"Adopte un artefact dérivé Cloud de courte durée approuvé comme fichier "
"principal de pièce jointe, avec des métadonnées de sauvegarde et de "
"restauration locales."

#: includes/Packages/Core_Write_Package.php:862
msgid "Set Post Featured Image"
msgstr "Définir l'image sélectionnée pour la publication"

#: includes/Packages/Core_Write_Package.php:863
msgid ""
"Sets a post featured image from an attachment ID or approved remote media "
"URL, or returns a dry-run preview by default."
msgstr ""
"Définit une image de publication à partir d'un ID de pièce jointe ou d'un "
"média distant approuvé URL, ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:893
msgid "Schedule Post"
msgstr "Programmer la publication"

#: includes/Packages/Core_Write_Package.php:894
msgid ""
"Schedules a post for future publication after host approval, or returns a "
"dry-run preview by default."
msgstr ""
"Planifie une publication pour une publication future après l'approbation de "
"l'hôte ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:927
msgid "Publish Post"
msgstr "Publier le message"

#: includes/Packages/Core_Write_Package.php:928
msgid ""
"Publishes a draft or pending post after host approval. Only treat the post "
"as publicly accessible after this succeeds."
msgstr ""
"Publie un brouillon ou une publication en attente après l'approbation de "
"l'hôte. Ne traitez la publication comme accessible au public qu'une fois cette"
"opération réussie."

#: includes/Packages/Core_Write_Package.php:954
msgid "Restore Post"
msgstr "Restaurer la publication"

#: includes/Packages/Core_Write_Package.php:955
msgid ""
"Restores a trashed post or page after host approval, or returns a dry-run "
"preview by default."
msgstr ""
"Restaure une publication ou une page supprimée après l'approbation de l'hôte, "
"ou renvoie un aperçu à sec par défaut."

#: includes/Packages/Core_Write_Package.php:980
msgid "Approve Comment"
msgstr "Approuver le commentaire"

#: includes/Packages/Core_Write_Package.php:981
msgid ""
