msgstr "Se requiere contenido para generar una propuesta de extracto."

#: includes/Packages/Core_Read_Package.php:3131
msgid "Local read-only excerpt proposal generated from explicit content input."
msgstr ""
"Propuesta de extracto local de solo lectura generada a partir de entradas de "
"contenido explícito."

#: includes/Packages/Core_Read_Package.php:3191
msgid "Post metadata plan resolved."
msgstr "Plan de publicación de metadatos resuelto."

#: includes/Packages/Core_Read_Package.php:3343
msgid "Menu was not found."
msgstr "No se encontró el menú."

