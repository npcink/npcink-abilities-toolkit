msgstr ""
"Capacidades de escritura WordPress gobernadas por el host con vistas previas "
"de prueba y aprobación externa."

#: includes/Packages/Core_Write_Package.php:79
msgid "Create Draft"
msgstr "Crear borrador"

#: includes/Packages/Core_Write_Package.php:80
