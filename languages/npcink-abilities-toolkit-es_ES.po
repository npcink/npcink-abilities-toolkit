#: includes/Packages/Core_Read_Package.php:73
msgid "WordPress Read Abilities"
msgstr "WordPress Leer habilidades"

#: includes/Packages/Core_Read_Package.php:74
msgid "Read-only WordPress site, content, and structure abilities."
msgstr "Capacidades de sitio, contenido y estructura de WordPress de solo lectura."

#: includes/Packages/Core_Read_Package.php:80
msgid "WordPress Page Abilities"
msgstr "WordPress Habilidades de la página"

#: includes/Packages/Core_Read_Package.php:81
msgid "Read-only WordPress page discovery and inspection abilities."
msgstr "Capacidades de inspección y descubrimiento de páginas WordPress de solo lectura."

#: includes/Packages/Core_Read_Package.php:87
msgid "WordPress Diagnostics"
msgstr "WordPress Diagnóstico"

#: includes/Packages/Core_Read_Package.php:88
msgid "Redacted WordPress environment diagnostics for Abilities API clients."
msgstr "Diagnóstico del entorno WordPress redactado para clientes Abilities API."

#: includes/Packages/Core_Read_Package.php:94
msgid "Workflow Recipe Definitions"
msgstr "Definiciones de recetas de flujo de trabajo"

#: includes/Packages/Core_Read_Package.php:95
msgid ""
"Read-only workflow recipe definitions for host-side ability composition."
msgstr ""
"Definiciones de recetas de flujo de trabajo de solo lectura para la "
"composición de capacidades del lado del host."

#: includes/Packages/Core_Read_Package.php:189
msgid "List Workflow Recipes"
msgstr "Listar recetas de flujo de trabajo"

#: includes/Packages/Core_Read_Package.php:190
msgid ""
"Returns read-only workflow recipe definitions for host-side ability "
"composition without executing workflow steps."
msgstr ""
"Devuelve definiciones de recetas de flujo de trabajo de solo lectura para la "
"composición de capacidades del lado del host sin ejecutar pasos del flujo de "
"trabajo."

#: includes/Packages/Core_Read_Package.php:212
msgid "Get Workflow Recipe"
msgstr "Obtener receta de flujo de trabajo"

#: includes/Packages/Core_Read_Package.php:213
msgid ""
"Returns one read-only workflow recipe definition by recipe id or case id "
"without executing workflow steps."
msgstr ""
"Devuelve una definición de receta de flujo de trabajo de solo lectura por ID "
"de receta o ID de caso sin ejecutar los pasos del flujo de trabajo."

#: includes/Packages/Core_Read_Package.php:233
msgid "List Media"
msgstr "Lista de medios"

#: includes/Packages/Core_Read_Package.php:234
msgid "Returns a paginated list of media library attachments."
msgstr "Devuelve una lista paginada de archivos adjuntos de la biblioteca multimedia."

#: includes/Packages/Core_Read_Package.php:279
msgid "Resolve Media Attachment By URL"
msgstr "Resolver archivo adjunto multimedia por URL"

#: includes/Packages/Core_Read_Package.php:280
msgid ""
"Resolves a same-site uploads URL to bounded media attachment candidates with "
"read-only match evidence."
msgstr ""
"Resuelve cargas en el mismo sitio URL a candidatos de archivos adjuntos de "
"medios delimitados con evidencia de coincidencia de solo lectura."

#: includes/Packages/Core_Read_Package.php:327
msgid "List Terms"
msgstr "Lista de términos"

#: includes/Packages/Core_Read_Package.php:328
msgid "Returns a paginated list of terms for a taxonomy."
msgstr "Devuelve una lista paginada de términos para una taxonomía."

#: includes/Packages/Core_Read_Package.php:371
msgid "List Taxonomy Terms"
msgstr "Listar términos de taxonomía"

#: includes/Packages/Core_Read_Package.php:372
msgid ""
"Returns a paginated term list for one taxonomy, including parent information."
msgstr ""
"Devuelve una lista de términos paginados para una taxonomía, incluida la "
"información principal."

#: includes/Packages/Core_Read_Package.php:418
msgid "List Categories"
msgstr "Listar categorías"

#: includes/Packages/Core_Read_Package.php:419
msgid "Returns a paginated list of post categories."
msgstr "Devuelve una lista paginada de categorías de publicaciones."

#: includes/Packages/Core_Read_Package.php:449
msgid "List Tags"
msgstr "Etiquetas de lista"

#: includes/Packages/Core_Read_Package.php:450
msgid "Returns a paginated list of post tags."
msgstr "Devuelve una lista paginada de etiquetas de publicaciones."

#: includes/Packages/Core_Read_Package.php:480
msgid "Get Term"
msgstr "Obtener plazo"

#: includes/Packages/Core_Read_Package.php:481
msgid "Returns details for one taxonomy term by id or slug."
msgstr "Devuelve detalles de un término de taxonomía por id o slug."

#: includes/Packages/Core_Read_Package.php:510
msgid "List Comments"
msgstr "Lista de comentarios"

#: includes/Packages/Core_Read_Package.php:511
msgid "Returns a paginated list of comments."
msgstr "Devuelve una lista paginada de comentarios."

#: includes/Packages/Core_Read_Package.php:553
msgid "Resolve Internal Link Targets"
msgstr "Resolver objetivos de enlaces internos"

#: includes/Packages/Core_Read_Package.php:554
msgid ""
"Finds local published content that can serve as internal-link targets for a "
"post draft or optimization workflow."
msgstr ""
"Encuentra contenido publicado local que puede servir como destino de enlaces "
"internos para un flujo de trabajo de optimización o borrador posterior."

#: includes/Packages/Core_Read_Package.php:599
msgid "Build Inline Image Blocks"
msgstr "Construir bloques de imágenes en línea"

#: includes/Packages/Core_Read_Package.php:600
msgid ""
"Converts uploaded inline image rows into append-ready Gutenberg image blocks "
"without writing post content."
msgstr ""
"Convierte filas de imágenes en línea cargadas en bloques de imágenes Gutenberg"
"listos para agregar sin escribir el contenido de la publicación."

#: includes/Packages/Core_Read_Package.php:635
msgid "Build Media SEO Assets"
msgstr "Crear recursos de medios SEO"

#: includes/Packages/Core_Read_Package.php:636
msgid ""
"Builds a canonical media SEO enrichment asset list from article media "
"workflow upload outputs."
msgstr ""
"Crea una lista de recursos de enriquecimiento de medios canónicos SEO a partir"
"de los resultados de carga del flujo de trabajo de medios de artículos."

#: includes/Packages/Core_Read_Package.php:668
msgid "GEO Analysis"
msgstr "GEO Análisis"

#: includes/Packages/Core_Read_Package.php:669
msgid ""
"Builds deterministic GEO and AI visibility issues, recommendations, and "
"evidence from article text."
msgstr ""
"Crea problemas, recomendaciones y evidencia deterministas de visibilidad GEO y"
"AI a partir del texto del artículo."

#: includes/Packages/Core_Read_Package.php:701
msgid "Optimize Media Metadata"
msgstr "Optimizar metadatos multimedia"

#: includes/Packages/Core_Read_Package.php:702
msgid ""
"Builds deterministic media title, alt, caption, description, source, and "
"disclosure suggestions from article and media context."
msgstr ""
"Crea sugerencias deterministas de títulos de medios, alternativas, subtítulos,"
"descripciones, fuentes y divulgación a partir del contexto del artículo y los "
"medios."

#: includes/Packages/Core_Read_Package.php:735
msgid "Position Inline Image Blocks"
msgstr "Colocar bloques de imágenes en línea"

#: includes/Packages/Core_Read_Package.php:736
msgid ""
"Places generated inline image blocks after matching paragraph, heading, or "
"anchor targets and falls back to append."
msgstr ""
"Coloca bloques de imágenes en línea generados después de hacer coincidir los "
"objetivos de párrafo, encabezado o ancla y vuelve a agregarlos."

#: includes/Packages/Core_Read_Package.php:771
msgid "Build Article Optimization Report"
msgstr "Crear informe de optimización de artículos"

#: includes/Packages/Core_Read_Package.php:772
msgid ""
"Composes SEO, GEO, internal-link, and media optimization sections into one "
"deterministic report."
msgstr ""
"Redacta las secciones SEO, GEO, enlaces internos y optimización de medios en "
"un informe determinista."

#: includes/Packages/Core_Read_Package.php:807
msgid "Build SEO Report Context"
msgstr "Crear contexto de informe SEO"

#: includes/Packages/Core_Read_Package.php:808
msgid ""
"Builds lightweight deterministic SEO issues and recommendations for article "
"optimization workflows."
msgstr ""
"Crea recomendaciones y problemas SEO deterministas ligeros para flujos de "
"trabajo de optimización de artículos."

#: includes/Packages/Core_Read_Package.php:840
msgid "Read Post Optimization Context"
msgstr "Leer contexto de optimización de publicaciones"

#: includes/Packages/Core_Read_Package.php:841
msgid ""
"Reads a post title, excerpt, content, slug, categories, tags, SEO fields, "
"template, and format snapshot for article optimization workflows."
msgstr ""
"Lee el título de una publicación, un extracto, un contenido, un slug, "
"categorías, etiquetas, campos SEO, una plantilla y una instantánea del formato"
"para los flujos de trabajo de optimización de artículos."

#: includes/Packages/Core_Read_Package.php:872
msgid "Build Article Single Optimization Suggest"
msgstr "Crear artículo Sugerencia de optimización única"

#: includes/Packages/Core_Read_Package.php:873
msgid ""
"Builds one canonical single-article optimization suggestion envelope for "
"title, taxonomy, excerpt, slug, SEO, content, and GEO improvements."
msgstr ""
"Crea un sobre canónico de sugerencias de optimización de un solo artículo para"
"mejoras de título, taxonomía, extracto, slug, SEO, contenido y GEO."

#: includes/Packages/Core_Read_Package.php:914
msgid "Build Article Optimization Apply Plan"
msgstr "Crear un plan de aplicación de optimización de artículos"

#: includes/Packages/Core_Read_Package.php:915
msgid ""
"Builds one conservative apply plan from the read-only article optimization "
"report without applying writes."
msgstr ""
"Crea un plan de aplicación conservador a partir del informe de optimización "
"del artículo de solo lectura sin aplicar escrituras."

#: includes/Packages/Core_Read_Package.php:950
msgid "Compose Article Optimization Apply Result"
msgstr "Redactar artículo Optimización Aplicar resultado"

#: includes/Packages/Core_Read_Package.php:951
msgid ""
"Composes report, apply plan, safe apply result, and remaining advisory "
"changes into one deterministic envelope."
msgstr ""
"Redacta el informe, el plan de aplicación, el resultado de la aplicación "
"segura y los cambios de aviso restantes en un sobre determinista."

#: includes/Packages/Core_Read_Package.php:984
msgid "Extract Reference Post Style"
msgstr "Extraer estilo de publicación de referencia"

#: includes/Packages/Core_Read_Package.php:985
msgid ""
"Reads reference posts and returns a compact writing-style profile for "
"article workflows."
msgstr ""
"Lee publicaciones de referencia y devuelve un perfil de estilo de escritura "
"compacto para los flujos de trabajo de artículos."

#: includes/Packages/Core_Read_Package.php:1032
msgid "Extract Site Style Baseline"
msgstr "Extraer línea base de estilo del sitio"

#: includes/Packages/Core_Read_Package.php:1033
msgid ""
"Extracts a lightweight site-wide or author-specific writing-style baseline "
"from recent posts."
msgstr ""
"Extrae una línea base ligera de estilo de escritura para todo el sitio o "
"específica del autor de publicaciones recientes."

#: includes/Packages/Core_Read_Package.php:1080
msgid "Build Article Production Fingerprint"
msgstr "Crear huella digital de producción de artículos"

#: includes/Packages/Core_Read_Package.php:1081
msgid ""
"Builds a stable lightweight production fingerprint for article dedupe and "
"result summaries."
msgstr ""
"Crea una huella digital de producción ligera y estable para la deduplicación "
"de artículos y resúmenes de resultados."

#: includes/Packages/Core_Read_Package.php:1124
msgid "Check Article Production Duplicate"
msgstr "Verificar producción de artículo duplicado"

#: includes/Packages/Core_Read_Package.php:1125
msgid ""
"Checks whether a lightweight article production fingerprint already exists "
"on a post."
msgstr ""
"Comprueba si ya existe una huella digital de producción de artículos livianos "
"en una publicación."

#: includes/Packages/Core_Read_Package.php:1152
msgid "Review Article Output Light"
msgstr "Artículo de revisión Luz de salida"

#: includes/Packages/Core_Read_Package.php:1153
msgid ""
"Builds lightweight local article quality, style, image, and AI-risk review "
"signals without model calls."
msgstr ""
"Crea señales ligeras de revisión de calidad, estilo, imagen y riesgo de AI de "
"artículos locales sin llamadas de modelo."

#: includes/Packages/Core_Read_Package.php:1190
msgid "Compose Article Production Result"
msgstr "Redactar el resultado de la producción del artículo"

#: includes/Packages/Core_Read_Package.php:1191
msgid ""
"Summarizes the article production mainline with result mode, degraded "
"reasons, fingerprint, handoff, and next action."
msgstr ""
"Resume la línea principal de producción del artículo con modo de resultado, "
"motivos degradados, huella digital, transferencia y siguiente acción."

#: includes/Packages/Core_Read_Package.php:1226
msgid "Compose Article Draft Result"
msgstr "Redactar el resultado del borrador del artículo"

#: includes/Packages/Core_Read_Package.php:1227
msgid ""
"Composes one canonical draft workflow result with draft content, metadata "
"resolution, shared SEO/GEO review, and handoff hints."
msgstr ""
"Compone un borrador canónico del resultado del flujo de trabajo con contenido "
"borrador, resolución de metadatos, revisión SEO/GEO compartida y sugerencias "
"de transferencia."

#: includes/Packages/Core_Read_Package.php:1263
msgid "Resolve Article Publication Decision"
msgstr "Resolver Decisión de Publicación del Artículo"

#: includes/Packages/Core_Read_Package.php:1264
msgid ""
"Resolves a deterministic article publish, schedule, review, or draft handoff "
"after quality and duplicate checks."
msgstr ""
"Resuelve la publicación, programación, revisión o entrega de borradores de un "
"artículo determinista después de verificaciones de calidad y duplicados."

#: includes/Packages/Core_Read_Package.php:1302
msgid "Build Article Style Profile"
msgstr "Crear perfil de estilo de artículo"

#: includes/Packages/Core_Read_Package.php:1303
msgid ""
"Merges baseline, reference, and explicit writing-style hints into one "
"lightweight article style profile."
msgstr ""
"Combina líneas de base, referencias y sugerencias de estilo de escritura "
"explícitas en un perfil de estilo de artículo liviano."

#: includes/Packages/Core_Read_Package.php:1339
msgid "List Pages"
msgstr "Listar páginas"

#: includes/Packages/Core_Read_Package.php:1340
msgid ""
"Lists WordPress pages with status, parent, search, sorting, and pagination "
"filters."
msgstr ""
"Enumera WordPress páginas con filtros de estado, principal, de búsqueda, de "
"clasificación y de paginación."

#: includes/Packages/Core_Read_Package.php:1372
msgid "Get Page"
msgstr "Obtener página"

#: includes/Packages/Core_Read_Package.php:1373
msgid ""
"Returns a single WordPress page, including content, template, hierarchy, "
"author, and optional meta."
msgstr ""
"Devuelve una única página WordPress, incluido el contenido, la plantilla, la "
"jerarquía, el autor y el metadato opcional."

#: includes/Packages/Core_Read_Package.php:1419
msgid "Inspect Page Structure"
msgstr "Inspeccionar la estructura de la página"

#: includes/Packages/Core_Read_Package.php:1420
msgid ""
"Inspects WordPress page hierarchy, template usage, and orphaned parent "
"relationships without modifying pages."
msgstr ""
"Inspecciona la jerarquía de páginas WordPress, el uso de plantillas y las "
"relaciones entre padres huérfanos sin modificar las páginas."

#: includes/Packages/Core_Read_Package.php:1449
msgid "List Pages Tree"
msgstr "Árbol de páginas de lista"

#: includes/Packages/Core_Read_Package.php:1450
msgid ""
"Returns a hierarchical page tree for navigation and site-structure review."
msgstr ""
"Devuelve un árbol de páginas jerárquico para navegación y revisión de la "
"estructura del sitio."

#: includes/Packages/Core_Read_Package.php:1490
msgid "Get Content Publishing Checklist"
msgstr "Obtenga la lista de verificación de publicación de contenido"

#: includes/Packages/Core_Read_Package.php:1491
msgid ""
"Returns a deterministic pre-publish readiness checklist for one post or page "
"without applying changes."
msgstr ""
"Devuelve una lista de verificación determinista de preparación previa a la "
"publicación para una publicación o página sin aplicar cambios."

#: includes/Packages/Core_Read_Package.php:1535
msgid "Get Content Inventory Health"
msgstr "Obtener estado del inventario de contenido"

#: includes/Packages/Core_Read_Package.php:1536
msgid ""
"Scans a bounded content inventory and summarizes missing titles, thin "
"content, excerpt gaps, media gaps, SEO metadata gaps, and stale content."
msgstr ""
"Escanea un inventario de contenido limitado y resume títulos faltantes, "
"contenido escaso, lagunas en extractos, lagunas en medios, SEO lagunas en "
"metadatos y contenido obsoleto."

#: includes/Packages/Core_Read_Package.php:1581
msgid "Get Nonproduction Content Inventory"
msgstr "Obtenga un inventario de contenido que no sea de producción"

#: includes/Packages/Core_Read_Package.php:1582
msgid ""
"Detects bounded smoke, fixture, and nonproduction content that may distort "
"content, taxonomy, comment, and operations diagnostics without mutating the "
"site."
msgstr ""
"Detecta humo limitado, elementos fijos y contenido que no es de producción que"
"puede distorsionar el contenido, la taxonomía, los comentarios y los "
"diagnósticos de operaciones sin alterar el sitio."

#: includes/Packages/Core_Read_Package.php:1615
msgid "Build Nonproduction Content Cleanup Plan"
msgstr "Crear un plan de limpieza de contenido que no sea de producción"

#: includes/Packages/Core_Read_Package.php:1616
msgid ""
"Builds a read-only cleanup plan for detected nonproduction content, mapping "
"each candidate to existing governed write abilities without trashing or "
"deleting anything."
msgstr ""
"Crea un plan de limpieza de solo lectura para contenido que no es de "
"producción detectado, asignando a cada candidato las capacidades de escritura "
"gobernadas existentes sin desechar ni eliminar nada."

#: includes/Packages/Core_Read_Package.php:1650
msgid "Build Content Inventory Fix Plan"
msgstr "Crear un plan de reparación de inventario de contenido"

#: includes/Packages/Core_Read_Package.php:1651
msgid ""
"Maps bounded content inventory issues to reviewable fix actions that reuse "
"existing governed write abilities without mutating posts."
msgstr ""
"Asigna problemas de inventario de contenido limitado a acciones de reparación "
"revisables que reutilizan las capacidades de escritura gobernadas existentes "
"sin mutar las publicaciones."

#: includes/Packages/Core_Read_Package.php:1685
msgid "Get Bulk Publishing Checklist"
msgstr "Obtenga la lista de verificación de publicación masiva"

#: includes/Packages/Core_Read_Package.php:1686
msgid ""
"Runs the read-only publishing checklist for a bounded list of posts and "
"returns batch readiness totals."
msgstr ""
"Ejecuta la lista de verificación de publicación de solo lectura para una lista"
"limitada de publicaciones y devuelve totales de preparación por lotes."

#: includes/Packages/Core_Read_Package.php:1732
msgid "Get Internal Link Opportunity Report"
msgstr "Obtenga el informe de oportunidades de enlaces internos"

#: includes/Packages/Core_Read_Package.php:1733
msgid ""
"Builds a post-id based internal-link opportunity report with candidate "
"targets, anchor suggestions, and placement hints."
msgstr ""
"Crea un informe de oportunidades de enlaces internos basado en una "
"identificación posterior con objetivos de candidatos, sugerencias de anclaje y"
"sugerencias de ubicación."

#: includes/Packages/Core_Read_Package.php:1773
msgid "Get Site Operations Dashboard"
msgstr "Obtenga el panel de operaciones del sitio"

#: includes/Packages/Core_Read_Package.php:1774
msgid ""
"Builds a bounded read-only site operations dashboard for content status, "
"inventory issues, taxonomy health, comments, and media signals."
msgstr ""
"Crea un panel de operaciones del sitio delimitado de solo lectura para el "
"estado del contenido, problemas de inventario, estado de la taxonomía, "
"comentarios y señales de medios."

#: includes/Packages/Core_Read_Package.php:1803
msgid "Get Post Publish Risk Report"
msgstr "Obtener informe de riesgo posterior a la publicación"

#: includes/Packages/Core_Read_Package.php:1804
msgid ""
"Builds a read-only publish risk report for one post from checklist, SEO/GEO, "
"revision, and internal-link signals."
msgstr ""
"Crea un informe de riesgo de publicación de solo lectura para una publicación "
"a partir de la lista de verificación, SEO/GEO, revisión y señales de enlaces "
"internos."

#: includes/Packages/Core_Read_Package.php:1834
msgid "Get Article Publish Preflight Context"
msgstr "Obtener artículo Publicar contexto de verificación previa"

#: includes/Packages/Core_Read_Package.php:1835
msgid ""
"Aggregates post context, publishing checklist, publish risk, workflow "
"context, and calendar context for host-side publish preflight workflows "
"without writing."
msgstr ""
"Agrega contexto de publicación, lista de verificación de publicación, riesgo "
"de publicación, contexto de flujo de trabajo y contexto de calendario para "
"flujos de trabajo de verificación previa de publicación del lado del host sin "
"escritura."

#: includes/Packages/Core_Read_Package.php:1867
msgid "Get Content Refresh Opportunities"
msgstr "Obtenga oportunidades de actualización de contenido"

#: includes/Packages/Core_Read_Package.php:1868
msgid ""
"Scans a bounded content set and returns stale, thin, SEO-light, answer-"
"light, and low-link refresh opportunities."
msgstr ""
"Escanea un conjunto de contenido limitado y devuelve oportunidades de "
"actualización obsoletas, delgadas, SEO ligeras, de respuesta ligera y de "
"enlaces bajos."

#: includes/Packages/Core_Read_Package.php:1900
msgid "Get Old Article Refresh Context"
msgstr "Obtener contexto de actualización de artículo antiguo"

#: includes/Packages/Core_Read_Package.php:1901
msgid ""
"Aggregates refresh opportunities, SEO/GEO gaps, site style baseline, "
"internal-link graph health, and optional selected-post link opportunities "
"for host-side old article refresh workflows."
msgstr ""
"Agrega oportunidades de actualización, brechas de SEO/GEO, línea base de "
"estilo del sitio, estado del gráfico de enlaces internos y oportunidades "
"opcionales de enlaces de publicaciones seleccionadas para flujos de trabajo de"
"actualización de artículos antiguos del lado del host."

#: includes/Packages/Core_Read_Package.php:1935
msgid "Get Internal Link Graph Health"
msgstr "Obtener el estado del gráfico de enlaces internos"

#: includes/Packages/Core_Read_Package.php:1936
msgid ""
"Scans a bounded content set and summarizes outgoing links, incoming links, "
"orphan posts, and candidate internal-link pairs."
msgstr ""
"Escanea un conjunto de contenido limitado y resume enlaces salientes, enlaces "
"entrantes, publicaciones huérfanas y pares de enlaces internos candidatos."

#: includes/Packages/Core_Read_Package.php:1968
msgid "Get Media Cleanup Opportunities"
msgstr "Obtenga oportunidades de limpieza de medios"

#: includes/Packages/Core_Read_Package.php:1969
msgid ""
"Scans a bounded media inventory and returns cleanup opportunities for "
"metadata gaps, source gaps, and likely unused assets."
msgstr ""
"Escanea un inventario de medios limitado y devuelve oportunidades de limpieza "
"para detectar lagunas en metadatos, lagunas en las fuentes y activos "
"probablemente no utilizados."

#: includes/Packages/Core_Read_Package.php:1998
msgid "List Media Backups"
msgstr "Listar copias de seguridad de medios"

#: includes/Packages/Core_Read_Package.php:1999
msgid ""
"Lists recorded backup files for one attachment media operation history "
"without mutating media."
msgstr ""
"Enumera los archivos de copia de seguridad grabados para el historial de "
"operaciones de un medio adjunto sin mutar el medio."

#: includes/Packages/Core_Read_Package.php:2028
msgid "Build Media Inventory Fix Plan"
msgstr "Crear un plan de reparación de inventario de medios"

#: includes/Packages/Core_Read_Package.php:2029
msgid ""
"Maps bounded media inventory issues to reviewable metadata and cleanup "
"actions that reuse existing governed write abilities without mutating media."
msgstr ""
"Asigna problemas de inventario de medios limitados a metadatos revisables y "
"acciones de limpieza que reutilizan las capacidades de escritura gobernadas "
"existentes sin mutar los medios."

#: includes/Packages/Core_Read_Package.php:2068
msgid "Build Media Reference Repair Plan"
msgstr "Crear plan de reparación de referencia de medios"

#: includes/Packages/Core_Read_Package.php:2069
msgid ""
"Scans post content for hard-coded URLs to a previously replaced media file "
"and builds governed patch-post-content actions without mutating posts."
msgstr ""
"Escanea el contenido de la publicación en busca de URLs codificados en un "
"archivo multimedia previamente reemplazado y crea acciones gobernadas de "
"parche-post-contenido sin mutar las publicaciones."

#: includes/Packages/Core_Read_Package.php:2104
msgid "Build Media Settings Reference Repair Plan"
msgstr "Plan de reparación de referencia de configuración de medios de compilación"

#: includes/Packages/Core_Read_Package.php:2105
msgid ""
"Scans selected WordPress options and theme mods for hard-coded URLs to a "
"previously replaced media file and builds governed exact replacement actions "
"without mutating settings."
msgstr ""
"Escanea las opciones de WordPress seleccionadas y las modificaciones de temas "
"en busca de URL codificados en un archivo multimedia previamente reemplazado y"
"las compilaciones rigen acciones de reemplazo exactas sin cambiar la "
"configuración."

#: includes/Packages/Core_Read_Package.php:2148
msgid "Get Taxonomy Consolidation Suggestions"
msgstr "Obtenga sugerencias de consolidación de taxonomía"

#: includes/Packages/Core_Read_Package.php:2149
msgid ""
"Scans taxonomy terms and suggests read-only consolidation candidates for "
"empty, duplicate, similar, and unused terms."
msgstr ""
"Analiza términos de taxonomía y sugiere candidatos de consolidación de solo "
"lectura para términos vacíos, duplicados, similares y no utilizados."

#: includes/Packages/Core_Read_Package.php:2179
msgid "Propose Post Taxonomy Terms"
msgstr "Proponer términos posteriores a la taxonomía"

#: includes/Packages/Core_Read_Package.php:2180
msgid ""
"Builds a deterministic post taxonomy assignment proposal from existing terms "
"without mutating the post or creating terms."
msgstr ""
"Crea una propuesta determinista de asignación de taxonomía posterior a partir "
"de términos existentes sin mutar la publicación ni crear términos."

#: includes/Packages/Core_Read_Package.php:2224
msgid "Get Page Structure Health"
msgstr "Obtener el estado de la estructura de la página"

#: includes/Packages/Core_Read_Package.php:2225
msgid ""
"Scans one page or a bounded page set and reports heading, CTA, content "
"depth, and block structure health."
msgstr ""
"Escanea una página o un conjunto de páginas delimitadas e informa el "
"encabezado, CTA, la profundidad del contenido y el estado de la estructura del"
"bloque."

#: includes/Packages/Core_Read_Package.php:2254
msgid "Get SEO GEO Gap Report"
msgstr "Obtenga informe de brechas de SEO GEO"

#: includes/Packages/Core_Read_Package.php:2255
msgid ""
"Builds a bounded SEO/GEO gap report from topic coverage, refresh "
"opportunities, answer structure, and SEO metadata signals."
msgstr ""
"Crea un informe de brechas SEO/GEO acotado a partir de la cobertura del tema, "
"las oportunidades de actualización, la estructura de respuestas y las señales "
"de metadatos SEO."

#: includes/Packages/Core_Read_Package.php:2286
msgid "Get Site Style Baseline"
msgstr "Obtener una línea base de estilo del sitio"

#: includes/Packages/Core_Read_Package.php:2287
msgid ""
"Returns a compact read-only site-wide or author-specific writing style "
"baseline from recent posts."
msgstr ""
"Devuelve una línea base compacta de solo lectura para todo el sitio o un "
"estilo de escritura específico del autor de publicaciones recientes."

#: includes/Packages/Core_Read_Package.php:2316
msgid "Build Article Workflow Context"
msgstr "Crear contexto de flujo de trabajo del artículo"

#: includes/Packages/Core_Read_Package.php:2317
msgid ""
"Builds one read-only context bundle for article refresh, publish, or new-"
"article workflows without model routing."
msgstr ""
"Crea un paquete de contexto de solo lectura para flujos de trabajo de "
"actualización, publicación o artículos nuevos sin enrutamiento de modelos."

#: includes/Packages/Core_Read_Package.php:2346
msgid "Get Publishing Calendar Context"
msgstr "Obtener contexto del calendario de publicación"

#: includes/Packages/Core_Read_Package.php:2347
msgid ""
"Returns scheduled posts, draft backlog, pending review items, and near-term "
"publishing cadence context."
msgstr ""
"Devuelve publicaciones programadas, borradores de trabajos pendientes, "
"elementos de revisión pendientes y contexto de cadencia de publicación a corto"
"plazo."

#: includes/Packages/Core_Read_Package.php:2376
msgid "Get Media Inventory Health"
msgstr "Obtener estado del inventario de medios"

#: includes/Packages/Core_Read_Package.php:2377
msgid ""
"Scans a bounded media inventory and summarizes missing alt text, captions, "
"descriptions, source metadata, and format attention."
msgstr ""
"Escanea un inventario de medios limitado y resume el texto alternativo, los "
"subtítulos, las descripciones, los metadatos de origen y la atención al "
"formato que faltan."

#: includes/Packages/Core_Read_Package.php:2420
msgid "Inspect Media Asset"
msgstr "Inspeccionar recursos multimedia"

#: includes/Packages/Core_Read_Package.php:2421
msgid ""
"Inspects one attachment file and returns read-only format, size, dimension, "
"and optimization recommendations."
msgstr ""
"Inspecciona un archivo adjunto y devuelve recomendaciones de optimización, "
"tamaño, dimensión y formato de solo lectura."

#: includes/Packages/Core_Read_Package.php:2473
msgid "Build Media Derivative Cloud Request"
msgstr "Crear solicitud de nube derivada de medios"

#: includes/Packages/Core_Read_Package.php:2474
msgid ""
"Builds a read-only request contract for a host or Cloud addon to generate an "
"optimized media derivative without uploading, calling Cloud, or mutating "
"WordPress."
msgstr ""
"Crea un contrato de solicitud de solo lectura para un host o complemento de la"
"nube para generar un derivado multimedia optimizado sin cargar, llamar a la "
"nube ni mutar WordPress."

#: includes/Packages/Core_Read_Package.php:2534
msgid "Build Media Optimization Plan"
msgstr "Crear un plan de optimización de medios"

#: includes/Packages/Core_Read_Package.php:2535
msgid ""
"Builds a read-only one-attachment optimization plan that combines reviewed "
"media metadata updates with a governed derivative adoption action for one "
"Core approval."
msgstr ""
"Crea un plan de optimización de un solo archivo adjunto de solo lectura que "
"combina actualizaciones de metadatos de medios revisados ​​con una acción de "
"adopción derivada gobernada para una aprobación de Core."

#: includes/Packages/Core_Read_Package.php:2568
msgid "Build Media Rename Plan"
msgstr "Crear un plan de cambio de nombre de medios"

#: includes/Packages/Core_Read_Package.php:2569
msgid ""
"Builds a read-only one-attachment rename plan for a reviewed target media "
"file name and exact post-content reference updates without mutating "
"WordPress."
msgstr ""
"Crea un plan de cambio de nombre de un solo archivo adjunto de solo lectura "
"para un nombre de archivo multimedia de destino revisado y actualizaciones "
"exactas de referencia posteriores al contenido sin mutar WordPress."

#: includes/Packages/Core_Read_Package.php:2606
msgid "Build Media Derivative Batch Plan"
msgstr "Crear un plan por lotes de derivados de medios"

#: includes/Packages/Core_Read_Package.php:2607
msgid ""
"Builds a bounded read-only plan for batch Cloud media derivative previews "
"from local media filters without calling Cloud, creating proposals, or "
"mutating WordPress."
msgstr ""
"Crea un plan limitado de solo lectura para vistas previas derivadas de medios "
"en la nube por lotes a partir de filtros de medios locales sin llamar a la "
"nube, crear propuestas ni mutar WordPress."

#: includes/Packages/Core_Read_Package.php:2690
msgid "Get Post SEO GEO Readiness"
msgstr "Obtener preparación para la publicación SEO GEO"

#: includes/Packages/Core_Read_Package.php:2691
msgid ""
"Returns one deterministic SEO/GEO readiness snapshot for a post, including "
"metadata, content-depth, question, and media signals."
msgstr ""
"Devuelve una instantánea determinista de preparación SEO/GEO para una "
"publicación, incluidos metadatos, profundidad del contenido, preguntas y "
"señales de medios."

#: includes/Packages/Core_Read_Package.php:2732
msgid "Get Site Topic Coverage Report"
msgstr "Obtener informe de cobertura de temas del sitio"

#: includes/Packages/Core_Read_Package.php:2733
msgid ""
"Builds a bounded site topic coverage summary from post titles, terms, and "
"content snippets without model routing."
msgstr ""
"Crea un resumen de cobertura de temas del sitio delimitado a partir de títulos"
"de publicaciones, términos y fragmentos de contenido sin enrutamiento modelo."

#: includes/Packages/Core_Read_Package.php:2775
msgid "Get Taxonomy Inventory Health"
msgstr "Obtener estado del inventario de taxonomía"

#: includes/Packages/Core_Read_Package.php:2776
msgid ""
"Scans a bounded taxonomy term inventory and summarizes empty, unused, "
"duplicate, and hierarchy attention signals."
msgstr ""
"Escanea un inventario de términos de taxonomía delimitados y resume las "
"señales de atención vacías, no utilizadas, duplicadas y jerárquicas."

#: includes/Packages/Core_Read_Package.php:2820
msgid "Get Revision Change Risk Report"
msgstr "Obtener informe de riesgo de cambio de revisión"

#: includes/Packages/Core_Read_Package.php:2821
msgid ""
"Reads recent revisions for one post and summarizes title, content length, "
"block count, and recency change-risk signals."
msgstr ""
"Lee revisiones recientes de una publicación y resume el título, la longitud "
"del contenido, el recuento de bloques y las señales de riesgo de cambios "
"recientes."

#: includes/Packages/Core_Read_Package.php:2903
msgid "Workflow recipe definition was not found."
msgstr "No se encontró la definición de la receta del flujo de trabajo."

#: includes/Packages/Core_Read_Package.php:3088
#: includes/Packages/Read_Traits/Content_Inventory_Read_Methods.php:35
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:44
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:281
#: includes/Packages/Read_Traits/Post_Primitives_Read_Methods.php:393
msgid "Post type does not exist."
msgstr "El tipo de publicación no existe."

#: includes/Packages/Core_Read_Package.php:3116
