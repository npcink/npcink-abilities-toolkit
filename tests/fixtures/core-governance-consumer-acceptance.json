{
  "schema_version": "v1",
  "purpose": "Consumer-side acceptance fixture for hosts that build Core governance proposals from discovered ability contracts.",
  "proposal_endpoint": "POST /wp-json/magick-ai-core/v1/proposals",
  "abilities": {
    "magick-ai/create-draft": {
      "risk_level": "write",
      "requires_approval": true,
      "required_scopes": [
        "post.write"
      ],
      "required_input": [
        "title"
      ],
      "must_have_input_controls": [
        "dry_run",
        "commit",
        "idempotency_key"
      ],
      "proposal_required_keys": [
        "ability_id",
        "title",
        "summary",
        "input",
        "preview",
        "caller"
      ]
    },
    "magick-ai/set-post-seo-meta": {
      "risk_level": "write",
      "requires_approval": true,
      "required_scopes": [
        "post.write"
      ],
      "required_input": [
        "post_id"
      ],
      "must_have_input_controls": [
        "dry_run",
        "commit",
        "idempotency_key"
      ],
      "proposal_required_keys": [
        "ability_id",
        "title",
        "summary",
        "input",
        "preview",
        "caller"
      ]
    },
    "magick-ai-abilities/list-workflow-recipes": {
      "risk_level": "read",
      "requires_approval": false,
      "required_scopes": [],
      "required_input": [],
      "must_have_input_controls": [],
      "proposal_required_keys": []
    }
  }
}
